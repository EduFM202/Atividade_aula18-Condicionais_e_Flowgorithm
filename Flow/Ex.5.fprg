    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="senha, nome" type="String" array="False" size=""/>
            <output expression="&quot;Verifica&#231;&#227;o de senha, fa&#231;a seu login:&quot;" newline="True"/>
            <output expression="&quot;Digite seu nome:&quot;" newline="True"/>
            <input variable="nome"/>
