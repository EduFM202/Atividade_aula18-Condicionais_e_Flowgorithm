            <input variable="senha"/>
            <if expression="senha = &quot;acb23&quot;">
                <then>
                    <output expression="&quot;Acesso autorizado!&quot;" newline="True"/>
                </then>
                <else>
                    <output expression="&quot;Senha incorreta!&quot;" newline="True"/>
                </else>
            </if>
